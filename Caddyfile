:80 {
	root * /site
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; object-src 'none'; base-uri 'none'; form-action 'self'; frame-ancestors {$ZEITFENSTER_ALLOWED_EMBED_ORIGINS:'none'}"
		Referrer-Policy "same-origin"
		X-Content-Type-Options "nosniff"
	}

	@booking {
		method POST
		path /book
	}
	request_body @booking {
		max_size 10KB
	}
	reverse_proxy @booking app:8000

	@health {
		path /health
	}
	reverse_proxy @health app:8000

	@api {
		path /api/*
	}
	reverse_proxy @api app:8000

	file_server
}
