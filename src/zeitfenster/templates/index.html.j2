{% extends "base.html.j2" %}

{% block content %}
<hgroup>
    <h1>{{ branding.title }}</h1>
    <p>Select a duration and pick a time that works for you.</p>
</hgroup>

{% if slots_by_duration %}
{% set duration_colors = ["#4a90d9", "#5ba870", "#d4833e"] %}
{% set duration_pastels = ["#dbeafe", "#d1fae5", "#ffedd5"] %}
<div class="duration-tabs" role="group">
    {% for duration in slots_by_duration %}
    <button class="duration-tab{% if loop.first %} active{% endif %}"
            data-duration="{{ duration }}"
            style="--duration-color: {{ duration_colors[(loop.index0) % duration_colors|length] }}; --duration-pastel: {{ duration_pastels[(loop.index0) % duration_pastels|length] }}">
        {{ duration }}
    </button>
    {% endfor %}
</div>

{% for duration, days in slots_by_duration.items() %}
<div class="slot-list" id="slots-{{ duration }}"
     style="--duration-color: {{ duration_colors[(loop.index0) % duration_colors|length] }}; --duration-pastel: {{ duration_pastels[(loop.index0) % duration_pastels|length] }}"
     {% if not loop.first %} hidden{% endif %}>
    {% if days %}
    {% for day_label, day_slots in days.items() %}
    <article>
        <header>{{ day_label }}</header>
        <div class="grid slot-grid">
            {% for slot in day_slots %}
            <form method="post" action="/book">
                <input type="hidden" name="slot_start" value="{{ slot.start_iso }}">
                <input type="hidden" name="slot_end" value="{{ slot.end_iso }}">
                <input type="hidden" name="duration" value="{{ duration }}">
                <input type="text" name="website" value="" class="honeypot" tabindex="-1" autocomplete="off">
                <button type="button" class="outline slot-button">
                    {{ slot.start_time }} – {{ slot.end_time }}
                </button>
            </form>
            {% endfor %}
        </div>
    </article>
    {% endfor %}
    {% else %}
    <article>
        <p>No available slots for this duration.</p>
    </article>
    {% endif %}
</div>
{% endfor %}

{% else %}
<article>
    <p>No available slots at this time. Please check back later.</p>
</article>
{% endif %}

<template id="booking-form-template">
    <div class="booking-form">
        <hr>
        <h4>Book this slot</h4>
        <label for="bf-name">Name
            <input type="text" id="bf-name" name="name" required maxlength="100" placeholder="Your name">
        </label>
        <label for="bf-email">Email
            <input type="email" id="bf-email" name="email" required maxlength="254" placeholder="your@email.com">
        </label>
        <button type="submit">Confirm Booking</button>
    </div>
</template>

{% endblock %}
